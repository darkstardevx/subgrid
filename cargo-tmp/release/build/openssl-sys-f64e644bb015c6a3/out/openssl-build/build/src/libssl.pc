# This file should be used when building against this OpenSSL build, and should never be installed
prefix=/opt/subgrid/cargo-tmp/release/build/openssl-sys-f64e644bb015c6a3/out/openssl-build/build/src
exec_prefix=${prefix}
libdir=${exec_prefix}
includedir=${prefix}/include ${prefix}/./include 

Name: OpenSSL-libssl
Description: Secure Sockets Layer and cryptography libraries
Version: 3.6.2
Requires.private: libcrypto
Libs: -L${libdir} -lssl
Cflags: -I${prefix}/include  -I${prefix}/./include 
